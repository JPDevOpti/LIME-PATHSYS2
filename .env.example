# Copia este archivo como .env si lo necesitas para otras variables (no pongas la URI de Atlas aquí).
# La URI de MongoDB Atlas va solo en run.sh (gitignored); plantilla: run.example.sh → copiar a run.sh

# ─── Seguridad ─────────────────────────────────────────────────────────────────
# JWT secret — obligatorio en producción (mínimo 32 caracteres aleatorios)
SECRET_KEY=cambia-esto-por-un-valor-aleatorio-seguro-de-32-chars

# ─── Producción Render (PathSys en pathsys.laboratorios-lime.com) ─────────────
# Servicio WEB (Next): Custom Domain = https://pathsys.laboratorios-lime.com
# Servicio API (FastAPI): ej. https://back-pathsys.onrender.com
#
# En Render → servicio del FRONT (variables de entorno del build y runtime):
#   NEXT_PUBLIC_API_URL=https://back-pathsys.onrender.com
#   NEXT_PUBLIC_SITE_URL=https://pathsys.laboratorios-lime.com
#
# En Render → servicio del BACK (variables):
#   CORS_ORIGINS=https://pathsys.laboratorios-lime.com
#   (añade más orígenes separados por coma si también usas www u onrender durante pruebas)

# ─── CORS (Back-End en Render u otro host) ─────────────────────────────────────
# Orígenes del front permitidos, separados por coma, sin barra final.
# CORS_ORIGINS=https://pathsys.laboratorios-lime.com

# ─── Referencia (generados automáticamente por run.sh, no editar aquí) ─────────
# Back-End/.env   →  MONGODB_URI, DATABASE_NAME, ENVIRONMENT, CORS_ORIGINS
# Front-End/.env  →  NEXT_PUBLIC_API_URL, NEXT_PUBLIC_SITE_URL
