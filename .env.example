# Copia este archivo como .env y completa los valores reales.
# run.sh lee este archivo para configurar el Back-End y Front-End automáticamente.

# ─── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Requerido para: ./run.sh atlas  y  ./run.sh clone-db
ATLAS_MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/

# ─── Seguridad ─────────────────────────────────────────────────────────────────
# JWT secret — obligatorio en producción (mínimo 32 caracteres aleatorios)
SECRET_KEY=cambia-esto-por-un-valor-aleatorio-seguro-de-32-chars

# ─── Referencia (generados automáticamente por run.sh, no editar aquí) ─────────
# Back-End/.env   →  MONGODB_URI, DATABASE_NAME, ENVIRONMENT, CORS_ORIGINS
# Front-End/.env.local  →  NEXT_PUBLIC_API_URL
